# =============================================================================
# CLIENT-SIDE (exposed to browser, OK to be public)
# =============================================================================
# Anyone with these can call your Supabase project as the anon role.
# RLS policies in supabase/schema.sql are what actually keep data safe.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# =============================================================================
# SERVER-SIDE (Cloudflare Pages secrets — NEVER commit, NEVER expose)
# =============================================================================
# Set these in: Cloudflare Pages → Project → Settings → Environment variables
# Mark them as "Secret" type so they're not visible in the dashboard.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
ANTHROPIC_API_KEY=sk-ant-...
